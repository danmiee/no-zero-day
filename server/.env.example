# Express server environment variables
# Copy to .env and fill in values.

# Port the Express server listens on
PORT=3001

# Comma-separated list of allowed CORS origins (added on top of the hardcoded defaults)
# Defaults already include: http://localhost:5173, http://localhost:4173, https://danmiee.github.io
CORS_ORIGIN=http://localhost:5173,https://danmiee.github.io

# Node environment
NODE_ENV=development
